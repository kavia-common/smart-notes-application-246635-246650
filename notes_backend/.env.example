# Smart Notes Backend - environment variables
#
# Copy to .env and fill values as needed. Do NOT commit secrets.

# Database connection string.
# - For Postgres (recommended):
#   postgresql+asyncpg://USER:PASSWORD@HOST:PORT/DB
# - If you only have a sync URL, you can also pass:
#   postgresql://USER:PASSWORD@HOST:PORT/DB
#   (the backend will convert it to asyncpg automatically)
DATABASE_URL=postgresql+asyncpg://appuser:dbuser123@localhost:5000/myapp

# JWT secret key used to sign access tokens (HS256).
# Use a long random value in production.
JWT_SECRET=change-me

# Token expiry in minutes (default: 10080 = 7 days)
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=10080

# Comma-separated list of allowed frontend origins for CORS.
# Example:
# CORS_ALLOW_ORIGINS=http://localhost:3000,https://your-frontend.example.com
CORS_ALLOW_ORIGINS=http://localhost:3000

# Auto-create DB tables on startup (useful for tests/dev; leave false in prod).
DB_AUTO_CREATE=false
